# ForgeMind Environment Configuration
# Copy this file to .env and fill in your API keys

# EverMemOS Cloud API
EVERMEMOS_API_URL=https://api.evermind.ai/v1
EVERMEMOS_API_KEY=your_evermemos_api_key_here
EVERMEMOS_USER_ID=your_user_id_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub (optional — required for GitHub ingestor)
GITHUB_TOKEN=your_github_token_here

# ForgeMind Settings
FORGEMIND_LOG_LEVEL=INFO
FORGEMIND_MEMORY_LANGUAGE=en
